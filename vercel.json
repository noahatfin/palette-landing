{
  "buildCommand": null,
  "outputDirectory": ".",
  "cleanUrls": true,
  "github": {
    "enabled": false
  },
  "headers": [
    {
      "source": "/imgs/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, no-cache" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, no-cache" }
      ]
    }
  ]
}
